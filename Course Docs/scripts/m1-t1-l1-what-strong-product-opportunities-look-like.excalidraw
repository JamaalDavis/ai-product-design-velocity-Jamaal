,"width":1130,"height":34,"backgroundColor":"#fff3bf","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"label":{"text":"3 EVALUATION QUESTIONS — run every hypothesis through these","fontSize":18}},{"type":"rectangle","id":"eq_e","x":20,"y":752,"width":350,"height":100,"backgroundColor":"#fff3bf","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"label":{"text":"E: Specific behaviour?\nNamed population?\nComparison group?","fontSize":18}},{"type":"rectangle","id":"eq_i","x":400,"y":752,"width":350,"height":100,"backgroundColor":"#fff3bf","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"label":{"text":"I: Does it show its working?\nCount x rate x $ estimate?","fontSize":18}},{"type":"rectangle","id":"eq_m","x":780,"y":752,"width":350,"height":100,"backgroundColor":"#fff3bf","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"label":{"text":"M: Root cause named?\nSpecific enough to scope?","fontSize":18}}],"appState":{"viewBackgroundColor":"#ffffff","currentItemFontFamily":1},"files":{}}
