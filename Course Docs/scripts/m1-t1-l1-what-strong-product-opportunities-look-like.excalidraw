{"type":"excalidraw","version":2,"source":"https://excalidraw.com","elements":[{"type":"text","id":"title","x":230,"y":12,"width":600,"height":34,"text":"What Strong Product Opportunities Look Like","fontSize":26,"strokeColor":"#1e1e1e","fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":24},{"type":"text","id":"subtitle","x":415,"y":46,"width":370,"height":28,"text":"The EIM Framework in action","fontSize":20,"strokeColor":"#666666","fontFamily":1,"textAlign":"left","verticalAlign":"top","baseline":18},{"type":"rectangle","id":"eh","x":20,"y":80,"width":350,"height":50,"backgroundColor":"#a5d8ff","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#4a9eed","strokeWidth":2,"label":{"text":"E — Evidence","fontSize":22}},{"type":"rectangle","id":"ih","x":400,"y":80,"width":350,"height":50,"backgroundColor":"#ffd8a8","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#f59e0b","strokeWidth":2,"label":{"text":"I — Impact","fontSize":22}},{"type":"rectangle","id":"mh","x":780,"y":80,"width":350,"height":50,"backgroundColor":"#d0bfff","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#8b5cf6","strokeWidth":2,"label":{"text":"M — Mechanism","fontSize":22}},{"type":"rectangle","id":"strong_banner","x":10,"y":148,"width":1130,"height":34,"backgroundColor":"#b2f2bb","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"label":{"text":"STRONG","fontSize":20}},{"type":"rectangle","id":"se","x":20,"y":194,"width":350,"height":240,"backgroundColor":"#b2f2bb","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strokeWidth":2,"label":{"text":"662 accounts skip taste profile\n329 also skip meal plan\n\n45.9% churn vs 8.5% (5.4x gap)\n\n+ Specific behaviour named\n+ Population sized (n=329)\n+ Comparison group present","fontSize":18}},{"type":"rectangle","id":"si","x":400,"y":194,"width":350,"height":240,"backgroundColor":"#b2f2bb","fillStyle":"solid","roundness":{"type":3},"strokeColor":"#22c55e","strok